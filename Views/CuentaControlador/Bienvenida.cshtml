@model PruebaFuego.Models.Usuario
@{
    ViewData["Title"] = "Detalles de la Cuenta";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">

    <div class="w-full max-w-2xl bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">

        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
            <div>
                <h2 class="text-xl font-semibold text-slate-900">Detalles de la cuenta</h2>
                <p class="text-sm text-slate-500">Información registrada en el sistema</p>
            </div>
            <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-800">
                @@@Model.Username
            </span>
        </div>

        <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-6">

            <div class="space-y-1">
                <p class="text-xs font-medium text-slate-400 uppercase">Nombres</p>
                <p class="text-slate-900 font-medium">@Model.Nombres</p>
            </div>

            <div class="space-y-1">
                <p class="text-xs font-medium text-slate-400 uppercase">Apellidos</p>
                <p class="text-slate-900 font-medium">@Model.Apellidos</p>
            </div>

            <div class="space-y-1 pt-2 border-t border-slate-50">
                <p class="text-xs font-medium text-slate-400 uppercase">DNI</p>
                <p class="text-slate-900 font-medium">@Model.Dni</p>
            </div>

            <div class="space-y-1 pt-2 border-t border-slate-50">
                <p class="text-xs font-medium text-slate-400 uppercase">Teléfono</p>
                <p class="text-slate-900 font-medium">@Model.Telefono</p>
            </div>

            <div class="space-y-1 pt-2 border-t border-slate-50 sm:col-span-2">
                <p class="text-xs font-medium text-slate-400 uppercase">Correo Electrónico</p>
                <p class="text-slate-900 font-medium">@Model.Correo</p>
            </div>

        </div>

        <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-end">
            <a href="/CuentaControlador/Login"
               class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">
                Cerrar sesión
            </a>
        </div>
    </div>

</body>
</html>